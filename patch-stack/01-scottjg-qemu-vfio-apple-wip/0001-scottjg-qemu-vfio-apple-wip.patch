+
+#include <linux/types.h>
+
+struct apple_dma_dev;
+
+enum apple_dma_stat_id {
+	APPLE_DMA_STAT_MAP,
+	APPLE_DMA_STAT_UNMAP,
+	APPLE_DMA_STAT_MAP_SG,
+	APPLE_DMA_STAT_UNMAP_SG,
