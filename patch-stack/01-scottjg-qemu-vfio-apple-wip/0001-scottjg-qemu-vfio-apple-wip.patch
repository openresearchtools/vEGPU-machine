+
+    kr = IOConnectCallMethod(connection,
+                             kSelectorProbeDMARegion,
+                             input, 2,
+                             NULL, 0,
+                             output, &outputCount,
+                             NULL, NULL);
+    if (kr != KERN_SUCCESS) {
+        return kr;
