+}
+
+kern_return_t
+apple_dext_config_write(io_connect_t connection,
+                            uint64_t offset,
+                            uint64_t width,
+                            uint64_t value)
+{
+    uint64_t input[3] = { offset, width, value };
+
+    if (connection == IO_OBJECT_NULL) {
+        return kIOReturnBadArgument;
+    }
+
+    return IOConnectCallMethod(connection,
+                               kSelectorConfigWrite,
