+
+struct apple_dma_dev *apple_dma_get(void);
+void apple_dma_trace_get_counts(struct apple_dma_dev *ad, u32 *maps,
+				u64 *bytes, u32 *window_count);
+void apple_dma_trace_get_total_counts(u32 *maps, u64 *bytes,
+				      u32 *window_count);
