+static kern_return_t
+vfio_user_mmio_read(VFIOUserPCIDriverUserClient *client,
+                    uint64_t memoryIndex,
+                    uint64_t offset,
+                    uint64_t width,
+                    uint64_t *outValue)
+{
+    if (client == nullptr || client->ivars == nullptr || outValue == nullptr) {
