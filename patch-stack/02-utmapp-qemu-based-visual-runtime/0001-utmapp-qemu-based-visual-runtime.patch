+{
+    if (ssd->iosurface) {
+        if (IOSurfaceGetHeight(ssd->iosurface) != height ||
+            IOSurfaceGetWidth(ssd->iosurface) != width) {
+            spice_iosurface_destroy(ssd);
+            return spice_iosurface_create(ssd, width, height);
+        }
+        return true;
+    }
+
+    return spice_iosurface_create(ssd, width, height);
+}
+
+static int spice_iosurface_create_fd(SimpleSpiceDisplay *ssd, int *fourcc)
+{
+    int fds[2];
+    IOSurfaceID surfaceid;
+
+    if (!ssd->iosurface) {
+        return -1;
+    }
+    if (qemu_socketpair(AF_UNIX, SOCK_STREAM, 0, fds) < 0) {
+        error_report("spice_iosurface_create_fd: failed to create socketpair");
+        return -1;
+    }
+    if (ssd->surface_send_fd > -1) {
+        close(ssd->surface_send_fd);
+    }
+    if (ssd->surface_recv_fd > -1) {
+        close(ssd->surface_recv_fd);
+    }
+
+    ssd->surface_recv_fd = fds[0];
+    ssd->surface_send_fd = fds[1];
+    *fourcc = 'BGRA';
+    surfaceid = IOSurfaceGetID(ssd->iosurface);
+    if (write(ssd->surface_send_fd, &surfaceid, sizeof(surfaceid)) !=
+        sizeof(surfaceid) ||
+        write(ssd->surface_recv_fd, &surfaceid, sizeof(surfaceid)) !=
+        sizeof(surfaceid)) {
+        close(fds[0]);
+        close(fds[1]);
+        ssd->surface_recv_fd = -1;
+        ssd->surface_send_fd = -1;
+        return -1;
+    }
+    return fds[0];
+}
+
+static void spice_iosurface_blit(SimpleSpiceDisplay *ssd, GLuint src_texture,
+                                 bool flip)
+{
+    egl_fb tmp_fb = {
+        .texture = src_texture,
+        .texture_target = GL_TEXTURE_2D,
+    };
+
+    if (!ssd->iosurface || !src_texture) {
+        return;
+    }
+
+#if defined(CONFIG_ANGLE)
+    if (ssd->esurface == EGL_NO_SURFACE) {
+        return;
+    }
+    eglMakeCurrent(qemu_egl_display, ssd->esurface, ssd->esurface, spice_gl_ctx);
+    egl_texture_blit(ssd->gls, &ssd->iosurface_fb, &tmp_fb, flip);
+#endif
+}
