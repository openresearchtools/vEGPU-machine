+private func configureAngleFrameworkDirectory(_ path: String) throws {
+    let expanded = (path as NSString).expandingTildeInPath
+    let url = URL(fileURLWithPath: expanded, isDirectory: true).standardizedFileURL
+    let fm = FileManager.default
+    var missing: [String] = []
+    for name in ["EGL", "GLESv2"] {
+        let framework = url.appendingPathComponent("\(name).framework", isDirectory: true)
+        let topLevelBinary = framework.appendingPathComponent(name).path
+        let versionedBinary = framework
+            .appendingPathComponent("Versions/Current", isDirectory: true)
+            .appendingPathComponent(name)
+            .path
+        if !fm.fileExists(atPath: topLevelBinary) && !fm.fileExists(atPath: versionedBinary) {
+            missing.append("\(name).framework")
+        }
+    }
+    guard missing.isEmpty else {
+        throw LaunchError.angleFrameworksMissing("\(url.path) is missing \(missing.joined(separator: ", "))")
+    }
+    prependEnvironmentPath("DYLD_FRAMEWORK_PATH", url.path)
+    prependEnvironmentPath("DYLD_FALLBACK_FRAMEWORK_PATH", url.path)
+    guard fm.changeCurrentDirectoryPath(url.path) else {
+        throw LaunchError.angleFrameworksMissing("could not chdir to \(url.path)")
+    }
+    log("angle frameworks: \(url.path)")
+}
