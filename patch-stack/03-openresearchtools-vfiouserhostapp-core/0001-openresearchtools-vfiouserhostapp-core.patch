+// Modified by OpenResearchTools, 2026-05-26.
+// SPDX-License-Identifier: GPL-2.0-or-later
+
+import AppKit
+import SwiftUI
+
+private let noticesResourceName = "ThirdPartyNotices"
+
+final class AboutWindowController: NSWindowController {
+    static let shared = AboutWindowController()
+
+    private init() {
+        let hosting = NSHostingController(rootView: AboutView())
+        let window = NSWindow(contentViewController: hosting)
+        window.title = "About vEGPU Machine"
+        window.styleMask = [.titled, .closable, .miniaturizable, .resizable]
+        window.setContentSize(NSSize(width: 720, height: 440))
+        window.minSize = NSSize(width: 620, height: 360)
+        window.isReleasedWhenClosed = false
+        super.init(window: window)
+    }
+
+    required init?(coder: NSCoder) {
+        fatalError("init(coder:) has not been implemented")
+    }
+
+    func show() {
+        guard let window else { return }
+        window.center()
+        window.makeKeyAndOrderFront(nil)
+        NSApp.activate(ignoringOtherApps: true)
+    }
+}
+
+final class NoticeWindowController: NSWindowController {
+    static let notices = NoticeWindowController(document: .notices)
+    static let licenses = NoticeWindowController(document: .licenses)
+
+    private init(document: NoticeDocument) {
+        let hosting = NSHostingController(rootView: NoticeDocumentView(document: document))
+        let window = NSWindow(contentViewController: hosting)
+        window.title = "\(document.title) - vEGPU Machine"
+        window.styleMask = [.titled, .closable, .miniaturizable, .resizable]
+        window.setContentSize(NSSize(width: 860, height: 640))
+        window.minSize = NSSize(width: 680, height: 460)
+        window.isReleasedWhenClosed = false
+        super.init(window: window)
+    }
+
+    required init?(coder: NSCoder) {
+        fatalError("init(coder:) has not been implemented")
+    }
+
+    func show() {
+        guard let window else { return }
+        window.center()
+        window.makeKeyAndOrderFront(nil)
+        NSApp.activate(ignoringOtherApps: true)
+    }
+}
+
+private struct AboutView: View {
+    var body: some View {
+        VStack(alignment: .leading, spacing: 18) {
+            HStack(alignment: .center, spacing: 16) {
+                Image(nsImage: NSApp.applicationIconImage)
+                    .resizable()
+                    .frame(width: 78, height: 78)
+                    .cornerRadius(14)
+
+                VStack(alignment: .leading, spacing: 5) {
+                    Text("vEGPU Machine")
+                        .font(.system(size: 30, weight: .semibold))
+                    Text(appVersionLine)
+                        .font(.callout)
+                        .foregroundStyle(.secondary)
+                }
+            }
+
+            Divider()
+
+            VStack(alignment: .leading, spacing: 11) {
+                Text("vEGPU Machine bundles the macOS DriverKit host, patched QEMU runtime, firmware, and guest tools for external GPU passthrough workflows.")
+
+                Text("DriverKit, VFIO, and QEMU integration work in this distribution is based on Scott J. Goldman's scottjg/qemu-vfio-apple repository at https://github.com/scottjg/qemu-vfio-apple, including work from its wip branch. We are grateful for his work enabling eGPU use on macOS, and we encourage users to follow the original project for its upstream progress.")
+
+                Text("The QEMU-side macOS SPICE/virgl rendering runtime also adapts work from the utmapp/qemu QEMU fork at https://github.com/utmapp/qemu and the utmapp/virglrenderer fork at https://github.com/utmapp/virglrenderer.")
+
+                Text("vEGPU Machine is not endorsed by, sponsored by, or affiliated with Scott J. Goldman, scottjg/qemu-vfio-apple, utmapp/qemu, utmapp/virglrenderer, or their maintainers. QEMU-derived code is distributed under the GPL version 2 terms applicable to QEMU; bundled dependencies carry their own notices and license texts.")
+            }
+            .font(.body)
+            .foregroundStyle(.primary)
+            .textSelection(.enabled)
+            .fixedSize(horizontal: false, vertical: true)
+
+            Spacer(minLength: 0)
+        }
+        .padding(24)
+        .frame(minWidth: 620, minHeight: 360)
+    }
+
+    private var appVersionLine: String {
+        let info = Bundle.main.infoDictionary ?? [:]
+        let version = info["CFBundleShortVersionString"] as? String ?? "1.0"
+        let build = info["CFBundleVersion"] as? String ?? ""
+        return build.isEmpty ? "Version \(version)" : "Version \(version) (\(build))"
+    }
+}
+
+private enum NoticeDocument: String {
+    case notices = "NOTICES"
+    case licenses = "LICENSES"
+
+    var title: String {
+        switch self {
+        case .notices: return "Notices"
+        case .licenses: return "Licenses"
+        }
+    }
+
+    var detail: String {
+        switch self {
+        case .notices:
+            return "Source layers, bundled components, source metadata, and acknowledgements"
+        case .licenses:
+            return "Complete license texts for bundled components"
+        }
+    }
+}
+
+private struct NoticeDocumentView: View {
+    let document: NoticeDocument
+    @State private var text = ""
+    @State private var loadError: String?
+
+    var body: some View {
+        VStack(alignment: .leading, spacing: 0) {
+            VStack(alignment: .leading, spacing: 3) {
+                Text(document.title)
+                    .font(.title2)
+                    .fontWeight(.semibold)
+                Text(document.detail)
+                    .font(.caption)
+                    .foregroundStyle(.secondary)
+            }
+            .padding([.top, .horizontal], 18)
+            .padding(.bottom, 12)
+
+            Divider()
+
+            if let loadError {
+                VStack(alignment: .leading, spacing: 10) {
+                    Text("Notice file unavailable")
+                        .font(.headline)
+                    Text(loadError)
+                        .font(.body)
+                        .foregroundStyle(.secondary)
+                        .textSelection(.enabled)
+                }
+                .padding(18)
+                Spacer()
+            } else {
+                PlainTextView(text: text)
+            }
+        }
+        .onAppear(perform: load)
+    }
+
+    private func load() {
+        guard let url = noticeURL(for: document) else {
+            text = ""
+            loadError = """
+            \(document.rawValue) was not found in the app bundle.
+
+            Build or package vEGPU Machine with Contents/Resources/\(noticesResourceName)/ populated by contrib/apple-vfio/scripts/make-notice-bundle.sh.
+            """
+            return
+        }
+
+        do {
+            text = try String(contentsOf: url, encoding: .utf8)
+            loadError = nil
+        } catch {
+            text = ""
+            loadError = "Could not read \(url.path): \(error.localizedDescription)"
+        }
+    }
+
+    private func noticeURL(for document: NoticeDocument) -> URL? {
+        let resources = Bundle.main.resourceURL
+        let bundled = resources?
+            .appendingPathComponent(noticesResourceName, isDirectory: true)
+            .appendingPathComponent(document.rawValue)
+        if let bundled, FileManager.default.fileExists(atPath: bundled.path) {
+            return bundled
+        }
+
+        let direct = resources?.appendingPathComponent(document.rawValue)
+        if let direct, FileManager.default.fileExists(atPath: direct.path) {
+            return direct
+        }
+
+        return nil
+    }
+}
+
+private struct PlainTextView: NSViewRepresentable {
+    let text: String
+
+    func makeNSView(context: Context) -> NSScrollView {
+        let scroll = NSScrollView()
+        scroll.hasVerticalScroller = true
+        scroll.hasHorizontalScroller = true
+        scroll.autohidesScrollers = false
+        scroll.borderType = .noBorder
+
+        let textView = NSTextView()
+        textView.isEditable = false
+        textView.isSelectable = true
+        textView.isRichText = false
+        textView.importsGraphics = false
+        textView.font = NSFont.monospacedSystemFont(ofSize: 11, weight: .regular)
+        textView.textColor = .textColor
+        textView.backgroundColor = .textBackgroundColor
+        textView.textContainerInset = NSSize(width: 12, height: 12)
+        textView.autoresizingMask = [.width]
+        textView.textContainer?.widthTracksTextView = false
+        textView.textContainer?.containerSize = NSSize(width: CGFloat.greatestFiniteMagnitude,
+                                                       height: CGFloat.greatestFiniteMagnitude)
+        scroll.documentView = textView
+        return scroll
+    }
+
+    func updateNSView(_ scroll: NSScrollView, context: Context) {
+        guard let textView = scroll.documentView as? NSTextView else { return }
+        if textView.string != text {
+            textView.string = text
+            textView.scrollToBeginningOfDocument(nil)
+        }
+    }
+}
