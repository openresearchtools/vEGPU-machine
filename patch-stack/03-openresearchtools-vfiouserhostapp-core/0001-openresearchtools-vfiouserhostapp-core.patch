+PKG_CONFIG_PATH="$DEPS_PKG_CONFIG_PATH" \
+pkg-config --modversion spice-protocol | grep -Fx "$SPICE_PROTOCOL_VERSION"
+PKG_CONFIG_PATH="$DEPS_PKG_CONFIG_PATH" \
+pkg-config --modversion spice-server | grep -Fx "$SPICE_SERVER_VERSION"
