+SPICE_PROTOCOL_SHA256="${SPICE_PROTOCOL_SHA256:-baf58449f6e89d19f475899ad5fb9196fdc46c03cc53233f4e39cf2978f9cff7}"
+SPICE_SERVER_VERSION="${SPICE_SERVER_VERSION:-0.16.0}"
+SPICE_SERVER_URL="${SPICE_SERVER_URL:-https://gitlab.freedesktop.org/-/project/62/uploads/54a0f9f5d1840e1ad8060cb560f3dde6/spice-${SPICE_SERVER_VERSION}.tar.bz2}"
+SPICE_SERVER_SHA256="${SPICE_SERVER_SHA256:-0a6ec9528f05371261bbb2d46ff35e7b5c45ff89bb975a99af95a5f20ff4717d}"
+VIRGL_REPO="${VIRGL_REPO:-https://github.com/utmapp/virglrenderer.git}"
+VIRGL_COMMIT="${VIRGL_COMMIT:-d48a2d0d9a722fffd3f92c83e71d9426a4892a66}"
