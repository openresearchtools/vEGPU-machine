@@ -0,0 +1,226 @@
+#!/bin/bash
+# Modified by OpenResearchTools, 2026-05-29.
+# SPDX-License-Identifier: GPL-2.0-or-later
+set -euo pipefail
+
+# SIP-disabled build: build without Xcode-managed signing, then ad-hoc sign
+# the app, dext, and bundled tools with the checked-in entitlements.
+
+HERE="$(cd "$(dirname "$0")" && pwd)"
+REPO_ROOT="$(cd "$HERE/../../.." && pwd)"
+APPLE_VFIO_DIR="$REPO_ROOT/contrib/apple-vfio"
+PROJECT="$APPLE_VFIO_DIR/VFIOUserHostApp.xcodeproj"
+DERIVED_DATA="${DERIVED_DATA:-$REPO_ROOT/build/xcode-nosip}"
+
+if [[ -z "${DEVELOPER_DIR:-}" ]]; then
+  DEVELOPER_DIR="$(xcode-select -p)"
+fi
+
+CONFIGURATION="${CONFIGURATION:-Debug}"
+SCHEME="${SCHEME:-VFIOUserHostApp}"
+ARCHS="${ARCHS:-arm64}"
+ONLY_ACTIVE_ARCH="${ONLY_ACTIVE_ARCH:-NO}"
+APP="$DERIVED_DATA/Build/Products/$CONFIGURATION/vEGPU Machine.app"
+DEXT="$APP/Contents/Library/SystemExtensions/scottjg.VFIOUserHostApp.VFIOUserPCIDriver.dext"
+GENERATED_NOTICES="${THIRD_PARTY_NOTICES_DIR:-$DERIVED_DATA/generated-third-party-notices}"
+NOTICE_DIST_DIR="${QEMU_DIST_DIR:-$REPO_ROOT/dist}"
+
+APP_ENT="$APPLE_VFIO_DIR/VFIOUserHostApp/VFIOUserHostApp.entitlements"
+DEXT_ENT="$APPLE_VFIO_DIR/VFIOUserPCIDriver/VFIOUserPCIDriver.entitlements"
+QEMU_ENT="$REPO_ROOT/accel/hvf/entitlements.plist"
+CLI_ENT="$APPLE_VFIO_DIR/qemu-vfio-apple/qemu-vfio-apple.entitlements"
+
+BUILD_ONLY=0
+if [[ "${1:-}" == "--build" ]]; then
+  BUILD_ONLY=1
+fi
+
+if [[ "$BUILD_ONLY" != "1" ]]; then
+  SIP_STATUS="$(csrutil status 2>&1 || true)"
+  if [[ "$SIP_STATUS" == *"enabled"* ]]; then
+    echo "ERROR: System Integrity Protection (SIP) is enabled."
+    echo "This no-SIP build uses ad-hoc signatures and is meant for SIP-disabled dev machines."
+    echo "Boot Recovery and run: csrutil disable"
+    exit 1
+  fi
+fi
+
+echo "Generating third-party notices from source/build inputs..."
+"$APPLE_VFIO_DIR/scripts/make-notice-bundle.sh" "$GENERATED_NOTICES" "$NOTICE_DIST_DIR"
+
+XCODE_VERSION_ARGS=()
+if [[ -n "${MARKETING_VERSION:-}" ]]; then
+  XCODE_VERSION_ARGS+=("MARKETING_VERSION=$MARKETING_VERSION")
+fi
+if [[ -n "${CURRENT_PROJECT_VERSION:-}" ]]; then
+  XCODE_VERSION_ARGS+=("CURRENT_PROJECT_VERSION=$CURRENT_PROJECT_VERSION")
+fi
+
+echo "Building vEGPU Machine without Xcode-managed signing..."
+DEVELOPER_DIR="$DEVELOPER_DIR" THIRD_PARTY_NOTICES_DIR="$GENERATED_NOTICES" xcodebuild clean build \
+  -project "$PROJECT" \
+  -scheme "$SCHEME" \
+  -configuration "$CONFIGURATION" \
+  -destination "generic/platform=macOS" \
+  -derivedDataPath "$DERIVED_DATA" \
+  ARCHS="$ARCHS" \
+  ONLY_ACTIVE_ARCH="$ONLY_ACTIVE_ARCH" \
+  "${XCODE_VERSION_ARGS[@]}" \
+  CODE_SIGN_IDENTITY="" \
+  CODE_SIGNING_REQUIRED=NO \
+  CODE_SIGNING_ALLOWED=NO \
+  DEVELOPMENT_TEAM="" \
+  PROVISIONING_PROFILE_SPECIFIER=""
+
+if [[ ! -d "$APP" ]]; then
+  echo "ERROR: app was not produced at $APP"
+  exit 1
+fi
+
+if [[ ! -d "$DEXT" ]]; then
+  echo "ERROR: dext was not embedded at $DEXT"
+  exit 1
+fi
+
+echo "Writing app release manifest..."
+python3 - "$APP" "$REPO_ROOT" <<'PY'
+import json
+import os
+import plistlib
+import subprocess
+import sys
+from pathlib import Path
+
+app = Path(sys.argv[1])
+repo_root = Path(sys.argv[2])
+info_path = app / "Contents" / "Info.plist"
+resources = app / "Contents" / "Resources"
+guest_manifest_path = resources / "guest-tools" / "manifest.json"
+out_path = resources / "manifest.json"
+
+with info_path.open("rb") as f:
+    info = plistlib.load(f)
+
+if guest_manifest_path.is_file():
+    with guest_manifest_path.open("r", encoding="utf-8") as f:
+        guest_manifest = json.load(f)
+else:
+    guest_manifest = {}
+
+def git_value(*args):
+    try:
+        return subprocess.check_output(
+            ["git", *args],
+            cwd=repo_root,
+            stderr=subprocess.DEVNULL,
+            text=True,
+        ).strip()
+    except Exception:
+        return ""
+
+source_revision = os.environ.get("GITHUB_SHA") or git_value("rev-parse", "HEAD")
+source_ref = os.environ.get("GITHUB_REF") or git_value("rev-parse", "--abbrev-ref", "HEAD")
+explicit_release_tag = os.environ.get("VGPU_RELEASE_TAG", "")
+if os.environ.get("VGPU_PUBLISH_RELEASE") == "true" and explicit_release_tag:
+    release_tag = explicit_release_tag
+else:
+    release_tag = os.environ.get("GITHUB_REF_NAME", "")
+    if os.environ.get("GITHUB_REF_TYPE") != "tag" and os.environ.get("GITHUB_EVENT_NAME") != "release":
+        release_tag = ""
+
+driver = guest_manifest.get("driver", {})
+kernels = guest_manifest.get("kernels")
+if not kernels and guest_manifest.get("kernel"):
+    kernel = dict(guest_manifest["kernel"])
+    kernel["prebuiltPackages"] = driver.get("prebuiltPackages", [])
+    kernels = [kernel]
+
+manifest = {
+    "manifestVersion": 1,
+    "product": "vEGPU Machine",
+    "bundleIdentifier": info.get("CFBundleIdentifier", ""),
+    "bundleName": info.get("CFBundleName", "vEGPU Machine"),
+    "version": info.get("CFBundleShortVersionString", ""),
+    "build": info.get("CFBundleVersion", ""),
+    "sourceRevision": source_revision,
+    "sourceRef": source_ref,
+    "releaseTag": release_tag,
+    "distribution": {
+        "format": "zip",
+        "installPath": "/Applications/vEGPU Machine.app",
+        "signing": "ad-hoc",
+        "hostPlatform": "macOS",
+        "arch": os.environ.get("ARCHS", "arm64"),
+    },
+    "guestTools": {
+        "manifestPath": "Contents/Resources/guest-tools/manifest.json",
+        "driverVersion": driver.get("version", ""),
+        "moduleName": driver.get("moduleName", "apple_dma"),
+        "dkmsPackages": driver.get("dkmsPackages", []),
+        "prebuiltPackages": driver.get("prebuiltPackages", []),
+        "kernels": kernels or [],
+    },
+}
+
+resources.mkdir(parents=True, exist_ok=True)
+with out_path.open("w", encoding="utf-8") as f:
+    json.dump(manifest, f, indent=2, sort_keys=True)
+    f.write("\n")
+PY
+
+sign_plain() {
+  local path="$1"
+  if [[ -e "$path" ]]; then
+    codesign --force --sign - --timestamp=none "$path"
+  fi
+}
+
+echo "Ad-hoc signing bundled QEMU support files..."
+if [[ -d "$APP/Contents/MacOS/lib" ]]; then
+  while IFS= read -r dylib; do
+    sign_plain "$dylib"
+  done < <(find "$APP/Contents/MacOS/lib" -type f -name '*.dylib' -print)
+fi
+
+sign_plain "$APP/Contents/MacOS/qemu-img"
+if [[ -f "$APP/Contents/MacOS/qemu-system-aarch64" ]]; then
+  codesign --force --sign - --timestamp=none --entitlements "$QEMU_ENT" \
+    "$APP/Contents/MacOS/qemu-system-aarch64"
+fi
+
+echo "Ad-hoc signing app helpers..."
+sign_plain "$APP/Contents/MacOS/vEGPU Machine.debug.dylib"
+sign_plain "$APP/Contents/MacOS/VFIOUserHostApp.debug.dylib"
+sign_plain "$APP/Contents/MacOS/__preview.dylib"
+if [[ -f "$APP/Contents/MacOS/qemu-vfio-apple" ]]; then
+  codesign --force --sign - --timestamp=none --entitlements "$CLI_ENT" \
+    "$APP/Contents/MacOS/qemu-vfio-apple"
+fi
+
+echo "Ad-hoc signing DriverKit extension..."
+codesign --force --sign - --timestamp=none --entitlements "$DEXT_ENT" "$DEXT"
+
+echo "Ad-hoc signing host app..."
+codesign --force --sign - --timestamp=none --entitlements "$APP_ENT" "$APP"
+
+codesign --verify --deep --strict --verbose=2 "$APP"
+codesign --verify --deep --strict --verbose=2 "$DEXT"
+
+echo "Build complete: $APP"
+
+if [[ -n "${GITHUB_OUTPUT:-}" ]]; then
+  echo "app=$APP" >> "$GITHUB_OUTPUT"
+  echo "dext=$DEXT" >> "$GITHUB_OUTPUT"
+  echo "notices_dir=$GENERATED_NOTICES" >> "$GITHUB_OUTPUT"
+fi
+
+if [[ "$BUILD_ONLY" == "1" ]]; then
+  exit 0
+fi
+
+DEST="/Applications/vEGPU Machine.app"
+echo "Installing to $DEST..."
+rm -rf "$DEST"
+ditto "$APP" "$DEST"
+echo "Installed: $DEST"
+echo "Open it from /Applications and use the app to activate the DriverKit extension."
