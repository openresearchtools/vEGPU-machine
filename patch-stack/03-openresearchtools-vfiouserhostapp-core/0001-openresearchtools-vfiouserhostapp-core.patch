diff --git a/contrib/apple-dma/scripts/build-guest-driver-bundle.sh b/contrib/apple-dma/scripts/build-guest-driver-bundle.sh
new file mode 100755
index 0000000000000000000000000000000000000000..84488eb9e83bff4cf64e7dfecbd81f7e26132a24
--- /dev/null
+++ b/contrib/apple-dma/scripts/build-guest-driver-bundle.sh
@@ -0,0 +1,303 @@
+#!/usr/bin/env bash
+# Modified by OpenResearchTools, 2026-05-26.
+# SPDX-License-Identifier: GPL-2.0-or-later
+set -euo pipefail
+
+HERE="$(cd "$(dirname "$0")" && pwd)"
+REPO_ROOT="$(cd "$HERE/../../.." && pwd)"
+DRIVER_SRC="$REPO_ROOT/contrib/apple-dma/linux"
+
+OUT_DIR="${OUT_DIR:-$REPO_ROOT/artifacts/guest-tools}"
+WORK_DIR="${WORK_DIR:-$REPO_ROOT/build/guest-tools-work}"
+BUNDLE_ROOT="$WORK_DIR/bundle-root"
+PKG_DIR="$WORK_DIR/packages"
+
+KERNEL_ABI="${KERNEL_ABI:-6.12.86+deb13-arm64}"
+KERNEL_DEBIAN_VERSION="${KERNEL_DEBIAN_VERSION:-6.12.86-1}"
+IMAGE_ID="${IMAGE_ID:-debian-13-generic-arm64-20260509-2473}"
+DEBIAN_IMAGE_URL="${DEBIAN_IMAGE_URL:-https://cloud.debian.org/images/cloud/trixie/20260509-2473/debian-13-generic-arm64-20260509-2473.qcow2}"
+DEBIAN_IMAGE_SHA512="${DEBIAN_IMAGE_SHA512:-16edf9daf931f2038d9f6ed4ee3e66d6e40c0cd3826dda83563a48ef1d76cb11a51ea9094b1e727deb4ed1bd253a58bd3c135c5cc77468ff64c1029878bc32dc}"
+NVIDIA_REPO="${NVIDIA_REPO:-https://developer.download.nvidia.com/compute/cuda/repos/debian13/sbsa}"
+REQUIRE_PREBUILT="${REQUIRE_PREBUILT:-0}"
+SOURCE_DATE_EPOCH="${SOURCE_DATE_EPOCH:-1767225600}"
+export SOURCE_DATE_EPOCH
+
+DRIVER_VERSION="$(awk -F'"' '/PACKAGE_VERSION/{print $2; exit}' "$DRIVER_SRC/dkms.conf")"
+PKG_VERSION="${DRIVER_VERSION}-1"
+SAFE_KERNEL_ABI="${KERNEL_ABI//+/-}"
+
+for tool in dpkg-deb jq sha512sum tar; do
+  if ! command -v "$tool" >/dev/null 2>&1; then
+    echo "error: required tool not found: $tool" >&2
+    exit 1
+  fi
+done
+
+rm -rf "$WORK_DIR" "$OUT_DIR/work"
+mkdir -p "$OUT_DIR" "$PKG_DIR" "$BUNDLE_ROOT/packages" "$BUNDLE_ROOT/source"
+
+copy_driver_source() {
+  local dest="$1"
+  mkdir -p "$dest"
+  tar -C "$DRIVER_SRC" \
+    --exclude='.git' \
+    --exclude='*.ko' \
+    --exclude='*.o' \
+    --exclude='*.mod' \
+    --exclude='*.mod.c' \
+    --exclude='*.cmd' \
+    --exclude='.tmp_versions' \
+    --exclude='Module.symvers' \
+    --exclude='modules.order' \
+    -cf - . | tar -C "$dest" -xf -
+}
+
+sha512_file() {
+  sha512sum "$1" | awk '{print $1}'
+}
+
+normalize_tree_mtime() {
+  local root="$1"
+  find "$root" -exec touch -h -d "@$SOURCE_DATE_EPOCH" {} +
+}
+
+create_reproducible_tar_gz() {
+  local src_dir="$1"
+  local output="$2"
+  tar -C "$src_dir" \
+    --sort=name \
+    --mtime="@$SOURCE_DATE_EPOCH" \
+    --owner=0 \
+    --group=0 \
+    --numeric-owner \
+    --use-compress-program='gzip -n' \
+    -cf "$output" .
+}
+
+package_entry_json() {
+  local file="$1"
+  local rel="packages/$(basename "$file")"
+  local sha
+  sha="$(sha512_file "$file")"
+  jq -n --arg path "$rel" --arg sha512 "$sha" '{path:$path, sha512:$sha512}'
+}
+
+build_dkms_package() {
+  local root="$WORK_DIR/apple-dma-dkms"
+  local package="$PKG_DIR/apple-dma-dkms_${PKG_VERSION}_all.deb"
+
+  mkdir -p "$root/DEBIAN" "$root/usr/src/apple-dma-$DRIVER_VERSION"
+  copy_driver_source "$root/usr/src/apple-dma-$DRIVER_VERSION"
+
+  cat >"$root/DEBIAN/control" <<EOF
+Package: apple-dma-dkms
+Version: $PKG_VERSION
+Section: kernel
+Priority: optional
+Architecture: all
+Depends: dkms, build-essential, kmod
+Maintainer: openresearchtools <no-reply@openresearchtools.com>
+Description: vEGPU guest DMA companion driver source
+ DKMS package for the guest-side apple_dma module used with the
+ vfio-apple QEMU passthrough device.
+EOF
+
+  cat >"$root/DEBIAN/postinst" <<EOF
+#!/bin/sh
+set -e
+if command -v dkms >/dev/null 2>&1; then
+  dkms remove -m apple-dma -v "$DRIVER_VERSION" --all >/dev/null 2>&1 || true
+  dkms add -m apple-dma -v "$DRIVER_VERSION" || true
+  dkms autoinstall -m apple-dma -v "$DRIVER_VERSION" || true
+fi
+if command -v update-initramfs >/dev/null 2>&1; then
+  update-initramfs -u || true
+fi
+modprobe apple_dma >/dev/null 2>&1 || true
+exit 0
+EOF
+
+  cat >"$root/DEBIAN/prerm" <<EOF
+#!/bin/sh
+set -e
+if command -v dkms >/dev/null 2>&1; then
+  dkms remove -m apple-dma -v "$DRIVER_VERSION" --all >/dev/null 2>&1 || true
+fi
+exit 0
+EOF
+
+  chmod 0755 "$root/DEBIAN/postinst" "$root/DEBIAN/prerm"
+  normalize_tree_mtime "$root"
+  dpkg-deb --build --root-owner-group "$root" "$package" >&2
+  printf '%s\n' "$package"
+}
+
+build_prebuilt_package() {
+  local headers="/lib/modules/$KERNEL_ABI/build"
+  local package="$PKG_DIR/apple-dma-modules-${SAFE_KERNEL_ABI}_${PKG_VERSION}_arm64.deb"
+  local module_dir="$WORK_DIR/module-build"
+  local root="$WORK_DIR/apple-dma-modules"
+
+  if [ ! -d "$headers" ]; then
+    if [ "$REQUIRE_PREBUILT" = "1" ]; then
+      echo "error: missing kernel headers at $headers" >&2
+      exit 1
+    fi
+    return 0
+  fi
+
+  copy_driver_source "$module_dir"
+  make -C "$headers" M="$module_dir" ARCH=arm64 CROSS_COMPILE="${CROSS_COMPILE:-}" modules >&2
+
+  mkdir -p "$root/DEBIAN" "$root/lib/modules/$KERNEL_ABI/extra" "$root/etc/modprobe.d" "$root/etc/modules-load.d"
+  install -m 0644 "$module_dir/apple_dma.ko" "$root/lib/modules/$KERNEL_ABI/extra/apple_dma.ko"
+  install -m 0644 "$DRIVER_SRC/apple-dma-options.conf" "$root/etc/modprobe.d/apple-dma-options.conf"
+  install -m 0644 "$DRIVER_SRC/apple-dma-load.conf" "$root/etc/modules-load.d/apple-dma-load.conf"
+
+  cat >"$root/DEBIAN/control" <<EOF
+Package: apple-dma-modules-$SAFE_KERNEL_ABI
+Version: $PKG_VERSION
+Section: kernel
+Priority: optional
+Architecture: arm64
+Depends: kmod
+Maintainer: openresearchtools <no-reply@openresearchtools.com>
+Description: vEGPU guest DMA companion module for $KERNEL_ABI
+ Prebuilt apple_dma.ko for Debian kernel $KERNEL_ABI
+ from the pinned $IMAGE_ID cloud image.
+EOF
+
+  cat >"$root/DEBIAN/postinst" <<EOF
+#!/bin/sh
+set -e
+depmod "$KERNEL_ABI" || true
+if command -v update-initramfs >/dev/null 2>&1; then
+  update-initramfs -u -k "$KERNEL_ABI" || true
+fi
+if [ "\$(uname -r)" = "$KERNEL_ABI" ]; then
+  modprobe apple_dma >/dev/null 2>&1 || true
+fi
+exit 0
+EOF
+
+  cat >"$root/DEBIAN/prerm" <<EOF
+#!/bin/sh
+set -e
+if [ "\$(uname -r)" = "$KERNEL_ABI" ]; then
+  rmmod apple_dma >/dev/null 2>&1 || true
+fi
+exit 0
+EOF
+
+  chmod 0755 "$root/DEBIAN/postinst" "$root/DEBIAN/prerm"
+  normalize_tree_mtime "$root"
+  dpkg-deb --build --root-owner-group "$root" "$package" >&2
+  printf '%s\n' "$package"
+}
+
+build_manifest() {
+  local dkms_package="$1"
+  local prebuilt_package="$2"
+  local dkms_json
+  local prebuilt_json
+
+  dkms_json="$(package_entry_json "$dkms_package" | jq -s '.')"
+  if [ -n "$prebuilt_package" ] && [ -f "$prebuilt_package" ]; then
+    prebuilt_json="$(package_entry_json "$prebuilt_package" | jq -s '.')"
+  else
+    prebuilt_json="[]"
+  fi
+
+  jq -n \
+    --arg id "$IMAGE_ID" \
+    --arg imageUrl "$DEBIAN_IMAGE_URL" \
+    --arg imageSha "$DEBIAN_IMAGE_SHA512" \
+    --arg kernel "$KERNEL_ABI" \
+    --arg kernelPackageVersion "$KERNEL_DEBIAN_VERSION" \
+    --arg driverVersion "$DRIVER_VERSION" \
+    --arg nvidiaRepo "$NVIDIA_REPO" \
+    --argjson prebuilt "$prebuilt_json" \
+    --argjson dkms "$dkms_json" \
+    '{
+      manifestVersion: 1,
+      id: $id,
+      createdBy: "vEGPU GitHub Actions guest-tools workflow",
+      debian: {
+        name: ($id + ".qcow2"),
+        url: $imageUrl,
+        sha512: $imageSha,
+        size: "408M",
+        variant: "generic"
+      },
+      kernel: {
+        version: $kernel,
+        debianPackageVersion: $kernelPackageVersion,
+        packages: []
+      },
+      kernels: [
+        {
+          version: $kernel,
+          debianPackageVersion: $kernelPackageVersion,
+          prebuiltPackages: $prebuilt
+        }
+      ],
+      driver: {
+        version: $driverVersion,
+        moduleName: "apple_dma",
+        prebuiltPackages: $prebuilt,
+        dkmsPackages: $dkms
+      },
+      nvidia: {
+        repository: $nvidiaRepo,
+        branch: "595",
+        cudaMajor: "13",
+        recommendedPackages: [
+          "nvidia-driver=595*",
+          "nvidia-open=595*",
+          "cuda-toolkit-13"
+        ]
+      },
+      guestPackages: []
+    }' >"$BUNDLE_ROOT/manifest.json"
+}
+
+DKMS_PACKAGE="$(build_dkms_package)"
+PREBUILT_PACKAGE="$(build_prebuilt_package || true)"
+
+cp "$DKMS_PACKAGE" "$BUNDLE_ROOT/packages/"
+if [ -n "$PREBUILT_PACKAGE" ] && [ -f "$PREBUILT_PACKAGE" ]; then
+  cp "$PREBUILT_PACKAGE" "$BUNDLE_ROOT/packages/"
+elif [ "$REQUIRE_PREBUILT" = "1" ]; then
+  echo "error: prebuilt module package was not produced" >&2
+  exit 1
+fi
+
+SOURCE_COPY="$WORK_DIR/source-copy"
+copy_driver_source "$SOURCE_COPY"
+normalize_tree_mtime "$SOURCE_COPY"
+create_reproducible_tar_gz "$SOURCE_COPY" "$BUNDLE_ROOT/source/apple-dma-$DRIVER_VERSION.tar.gz"
+
+cat >"$BUNDLE_ROOT/README.txt" <<EOF
+vEGPU guest tools for $IMAGE_ID
+
+This bundle contains the guest-side DMA driver package for the pinned Debian
+cloud image. vEGPU syncs this manifest and these packages over SSH after
+the cloud-init seed brings up the base VM; this artifact does not contain
+a modified Debian image.
+
+Kernel: $KERNEL_ABI ($KERNEL_DEBIAN_VERSION)
+Driver: apple_dma $DRIVER_VERSION
+NVIDIA/CUDA repo: $NVIDIA_REPO
+EOF
+
+build_manifest "$DKMS_PACKAGE" "$PREBUILT_PACKAGE"
+cp "$BUNDLE_ROOT/manifest.json" "$OUT_DIR/manifest.json"
+rm -rf "$OUT_DIR/packages" "$OUT_DIR/source"
+cp -R "$BUNDLE_ROOT/packages" "$OUT_DIR/packages"
+cp -R "$BUNDLE_ROOT/source" "$OUT_DIR/source"
+
+create_reproducible_tar_gz "$BUNDLE_ROOT" "$OUT_DIR/vegpu-guest-driver-bundle.tar.gz"
+sha512sum "$OUT_DIR"/vegpu-guest-driver-bundle.tar.gz "$OUT_DIR"/manifest.json >"$OUT_DIR/SHA512SUMS"
+rm -rf "$WORK_DIR"
+
+echo "Built guest driver bundle in $OUT_DIR"
diff --git a/contrib/apple-dma/scripts/merge-guest-driver-bundles.sh b/contrib/apple-dma/scripts/merge-guest-driver-bundles.sh
new file mode 100755
index 0000000000000000000000000000000000000000..e174bbefc42466fa1895da6f2176448ce3d09c0d
--- /dev/null
+++ b/contrib/apple-dma/scripts/merge-guest-driver-bundles.sh
@@ -0,0 +1,168 @@
+#!/usr/bin/env bash
+# Modified by OpenResearchTools, 2026-05-26.
+# SPDX-License-Identifier: GPL-2.0-or-later
+set -euo pipefail
+
+if [ "$#" -lt 2 ]; then
+  echo "usage: $0 OUT_DIR GUEST_TOOLS_PART..." >&2
+  exit 2
+fi
+
+OUT_DIR="$1"
+shift
+
+for tool in python3 shasum tar; do
+  if ! command -v "$tool" >/dev/null 2>&1; then
+    echo "error: required tool not found: $tool" >&2
+    exit 1
+  fi
+done
+
+rm -rf "$OUT_DIR"
+mkdir -p "$OUT_DIR/packages" "$OUT_DIR/source"
+
+python3 - "$OUT_DIR" "$@" <<'PY'
+import hashlib
+import json
+import os
+import shutil
+import sys
+from pathlib import Path
+
+out = Path(sys.argv[1])
+parts = [Path(p) for p in sys.argv[2:]]
+manifests = []
+
+def sha512(path: Path) -> str:
+    h = hashlib.sha512()
+    with path.open("rb") as f:
+        for chunk in iter(lambda: f.read(1024 * 1024), b""):
+            h.update(chunk)
+    return h.hexdigest()
+
+def copy_tree_files(src_dir: Path, dst_dir: Path) -> None:
+    if not src_dir.is_dir():
+        return
+    for src in sorted(p for p in src_dir.rglob("*") if p.is_file()):
+        rel = src.relative_to(src_dir)
+        dst = dst_dir / rel
+        dst.parent.mkdir(parents=True, exist_ok=True)
+        if dst.exists():
+            if sha512(src) != sha512(dst):
+                if is_shared_generated_artifact(rel):
+                    print(f"reusing first generated guest-tools artifact: {rel}", file=sys.stderr)
+                    continue
+                raise SystemExit(f"conflicting guest-tools file: {rel}")
+            continue
+        shutil.copy2(src, dst)
+
+def is_shared_generated_artifact(rel: Path) -> bool:
+    rel_text = rel.as_posix()
+    return (
+        rel_text.startswith("packages/apple-dma-dkms_")
+        or rel_text.startswith("apple-dma-dkms_")
+        or rel_text.startswith("source/apple-dma-")
+        or rel_text.startswith("apple-dma-")
+    )
+
+def unique_entries(entries):
+    seen = {}
+    result = []
+    for entry in entries:
+        path = entry.get("path")
+        sha = entry.get("sha512")
+        if path in seen:
+            if seen[path] != sha:
+                rel = Path(path)
+                if is_shared_generated_artifact(rel):
+                    continue
+                raise SystemExit(f"conflicting manifest entry for {path}")
+            continue
+        seen[path] = sha
+        result.append(entry)
+    return result
+
+for part in parts:
+    manifest_path = part / "manifest.json"
+    if not manifest_path.is_file():
+        continue
+    with manifest_path.open("r", encoding="utf-8") as f:
+        manifest = json.load(f)
+    manifests.append(manifest)
+    copy_tree_files(part / "packages", out / "packages")
+    copy_tree_files(part / "source", out / "source")
+
+if not manifests:
+    raise SystemExit("no guest-tools manifests found")
+
+base = manifests[0]
+dkms_packages = []
+prebuilt_packages = []
+kernels = []
+seen_kernels = set()
+
+for manifest in manifests:
+    driver = manifest.get("driver", {})
+    dkms_packages.extend(driver.get("dkmsPackages", []))
+    prebuilt = driver.get("prebuiltPackages", [])
+    prebuilt_packages.extend(prebuilt)
+
+    manifest_kernels = manifest.get("kernels")
+    if not manifest_kernels and manifest.get("kernel"):
+        kernel = dict(manifest["kernel"])
+        kernel["prebuiltPackages"] = prebuilt
+        manifest_kernels = [kernel]
+
+    for kernel in manifest_kernels or []:
+        version = kernel.get("version")
+        if not version or version in seen_kernels:
+            continue
+        seen_kernels.add(version)
+        kernels.append(kernel)
+
+dkms_packages = unique_entries(dkms_packages)
+prebuilt_packages = unique_entries(prebuilt_packages)
+kernels = sorted(kernels, key=lambda k: k.get("version", ""))
+
+driver = dict(base.get("driver", {}))
+driver["dkmsPackages"] = dkms_packages
+driver["prebuiltPackages"] = prebuilt_packages
+
+merged = {
+    "manifestVersion": 2,
+    "id": base.get("id"),
+    "createdBy": "vEGPU GitHub Actions guest-tools merge workflow",
+    "debian": base.get("debian", {}),
+    "kernel": kernels[0] if kernels else base.get("kernel", {}),
+    "kernels": kernels,
+    "driver": driver,
+    "nvidia": base.get("nvidia", {}),
+    "guestPackages": base.get("guestPackages", []),
+}
+
+with (out / "manifest.json").open("w", encoding="utf-8") as f:
+    json.dump(merged, f, indent=2, sort_keys=True)
+    f.write("\n")
+PY
+
+cat >"$OUT_DIR/README.txt" <<'EOF'
+vEGPU guest tools
+
+This directory contains the guest-side apple_dma DKMS source package,
+prebuilt apple_dma module packages for the Debian kernels listed in
+manifest.json, and the guest-driver source archive.
+EOF
+
+tar -C "$OUT_DIR" -czf "$OUT_DIR/vegpu-guest-driver-bundle.tar.gz" \
+  README.txt manifest.json packages source
+
+(
+  cd "$OUT_DIR"
+  find packages source -type f -print | sort > .sha-files
+  printf '%s\n' vegpu-guest-driver-bundle.tar.gz manifest.json >> .sha-files
+  shasum -a 512 $(cat .sha-files) > SHA512SUMS
+  rm -f .sha-files
+  shasum -a 512 -c SHA512SUMS
+)
+
+echo "Merged guest driver bundle in $OUT_DIR"
