+#!/usr/bin/env bash
+# Modified by OpenResearchTools, 2026-05-26.
+# SPDX-License-Identifier: GPL-2.0-or-later
+set -euo pipefail
+
+HERE="$(cd "$(dirname "$0")" && pwd)"
+REPO_ROOT="$(cd "$HERE/../../.." && pwd)"
+
+APP="${1:-${APP_PATH:-$REPO_ROOT/build/xcode-nosip/Build/Products/Debug/vEGPU Machine.app}}"
+OUT="${2:-${PKG_OUT:-$REPO_ROOT/artifacts/vEGPU-Machine.pkg}}"
+IDENTIFIER="${PKG_IDENTIFIER:-com.openresearchtools.vEGPUMachine.pkg}"
+VERSION="${PKG_VERSION:-0.1.1}"
+
+if [[ ! -d "$APP" ]]; then
+  echo "error: app bundle not found: $APP" >&2
+  echo "Build it first, for example: contrib/apple-vfio/scripts/build-nosip.sh --build" >&2
+  exit 1
+fi
+
+if [[ ! -x "$APP/Contents/MacOS/vEGPU Machine" && ! -x "$APP/Contents/MacOS/VFIOUserHostApp" ]]; then
+  echo "error: malformed app bundle, missing host executable: $APP" >&2
+  exit 1
+fi
+
+if [[ ! -x "$APP/Contents/MacOS/qemu-system-aarch64" ]]; then
+  echo "error: app bundle does not contain qemu-system-aarch64: $APP" >&2
+  echo "Build with QEMU_DIST_DIR or an in-tree dist/ so vEGPU Machine.app contains QEMU." >&2
+  exit 1
+fi
+
+mkdir -p "$(dirname "$OUT")"
+rm -f "$OUT"
+
+STAGE="$(mktemp -d "${TMPDIR:-/tmp}/vEGPU-Machine-pkg.XXXXXX")"
+COMPONENTS="$(mktemp "${TMPDIR:-/tmp}/vEGPU-Machine-components.XXXXXX")"
+trap 'rm -rf "$STAGE" "$COMPONENTS"' EXIT
+
+mkdir -p "$STAGE/Applications"
+ditto "$APP" "$STAGE/Applications/vEGPU Machine.app"
+
+pkgbuild --analyze --root "$STAGE" "$COMPONENTS" >/dev/null
+/usr/libexec/PlistBuddy -c 'Set :0:BundleIsRelocatable false' "$COMPONENTS"
+/usr/libexec/PlistBuddy -c 'Set :0:BundleOverwriteAction upgrade' "$COMPONENTS"
+
+ARGS=(
+  --root "$STAGE"
+  --component-plist "$COMPONENTS"
+  --install-location /
+  --identifier "$IDENTIFIER"
+  --version "$VERSION"
+)
+
+if [[ -n "${INSTALLER_SIGN_IDENTITY:-}" ]]; then
+  ARGS+=(--sign "$INSTALLER_SIGN_IDENTITY")
+fi
+
+pkgbuild "${ARGS[@]}" "$OUT" >&2
+echo "$OUT"
