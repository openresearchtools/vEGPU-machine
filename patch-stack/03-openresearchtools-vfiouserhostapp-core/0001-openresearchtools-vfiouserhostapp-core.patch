+    tap_head = formula_info.get("tap_git_head")
+    ruby_source_path = formula_info.get("ruby_source_path")
+    if tap_head and ruby_source_path:
+        ruby_url = (
+            "https://raw.githubusercontent.com/Homebrew/homebrew-core/"
+            f"{tap_head}/{ruby_source_path}"
+        )
+        ruby_source = fetch_bytes(ruby_url, f"{formula} Homebrew formula recipe")
+        save_source_package_file(
+            pathlib.PurePosixPath(dep_key) / "HOMEBREW_FORMULA.rb",
+            ruby_source,
+        )
+
+    for resource in formula_info.get("resources", []) or []:
+        resource_name = resource.get("name") or "resource"
+        resource_url = resource.get("url")
+        if not resource_url:
+            urls = resource.get("urls") or {}
+            stable = urls.get("stable") if isinstance(urls, dict) else None
+            if isinstance(stable, dict):
+                resource_url = stable.get("url")
+        if not resource_url:
+            raise RuntimeError(
