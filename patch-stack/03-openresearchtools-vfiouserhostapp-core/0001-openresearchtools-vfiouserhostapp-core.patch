diff --git a/hw/vfio/apple-auto.c b/hw/vfio/apple-auto.c
new file mode 100644
index 0000000000000000000000000000000000000000..8a7163015886e83552c608e99c2c27ae338bb751
--- /dev/null
+++ b/hw/vfio/apple-auto.c
@@ -0,0 +1,334 @@
+/*
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ *
+ * QEMU-side auto passthrough for Apple DriverKit VFIO devices.
+ *
+ * This pseudo-device intentionally does not ask a helper process for BDFs.
+ * It enumerates the live VFIOUserPCIDriver-bound PCI functions inside the
+ * qemu-system-aarch64 process, then creates vfio-apple-pci devices in that
+ * same process so the DriverKit open/claim happens in the VM owner process.
+ */
+
+/*
+ * Modified by OpenResearchTools, 2026-05-26.
+ */
+
+#include "qemu/osdep.h"
+
+#include "hw/pci/pci.h"
+#include "hw/pci/pci_bus.h"
+#include "hw/core/qdev-properties.h"
+#include "hw/vfio/apple.h"
+#include "hw/vfio/apple-dext-client.h"
+#include "hw/vfio/types.h"
+#include "qapi/error.h"
+#include "qemu/error-report.h"
+#include "qemu/units.h"
+#include "qom/object.h"
+
+OBJECT_DECLARE_SIMPLE_TYPE(VFIOAppleAutoPCIDevice, VFIO_APPLE_AUTO_PCI)
+
+struct VFIOAppleAutoPCIDevice {
+    DeviceState parent_obj;
+    bool dma_companion;
+    uint64_t dma_bounce_size;
+    uint8_t guest_slot_start;
+};
+
+typedef struct AppleAutoGroup {
+    uint8_t bus;
+    uint8_t device;
+    uint8_t first_function;
+    uint8_t guest_slot;
+    size_t count;
+    char root[128];
+} AppleAutoGroup;
+
+typedef struct AppleAutoBusSearch {
+    PCIBus *bus;
+} AppleAutoBusSearch;
+
+static int
+apple_auto_find_root_pci_bus(Object *child, void *opaque)
+{
+    AppleAutoBusSearch *search = opaque;
+
+    if (search->bus != NULL) {
+        return 1;
+    }
+
+    if (object_dynamic_cast(child, TYPE_PCI_BUS) != NULL) {
+        PCIBus *bus = PCI_BUS(child);
+
+        if (pci_bus_is_root(bus)) {
+            search->bus = bus;
+            return 1;
+        }
+    }
+
+    return 0;
+}
+
+static PCIBus *
+apple_auto_primary_pci_bus(void)
+{
+    AppleAutoBusSearch search = { 0 };
+
+    object_child_foreach_recursive(object_get_root(),
+                                   apple_auto_find_root_pci_bus,
+                                   &search);
+    return search.bus;
+}
+
+static int
+apple_dext_bound_device_cmp(const void *ap, const void *bp)
+{
+    const AppleDextBoundDevice *a = ap;
+    const AppleDextBoundDevice *b = bp;
+    int root_cmp = strcmp(a->root, b->root);
+
+    if (root_cmp != 0) {
+        return root_cmp;
+    }
+    if (a->bus != b->bus) {
+        return (int)a->bus - (int)b->bus;
+    }
+    if (a->device != b->device) {
+        return (int)a->device - (int)b->device;
+    }
+    return (int)a->function - (int)b->function;
+}
+
+static int
+apple_auto_group_for(AppleAutoGroup *groups, size_t group_count,
+                     const AppleDextBoundDevice *dev)
+{
+    for (size_t i = 0; i < group_count; i++) {
+        if (groups[i].bus == dev->bus &&
+            groups[i].device == dev->device &&
+            strcmp(groups[i].root, dev->root) == 0) {
+            return (int)i;
+        }
+    }
+    return -1;
+}
+
+static bool
+apple_auto_prepare_groups(const AppleDextBoundDevice *devices, size_t count,
+                          uint8_t guest_slot_start,
+                          AppleAutoGroup **out_groups,
+                          size_t *out_group_count,
+                          Error **errp)
+{
+    AppleAutoGroup *groups = g_new0(AppleAutoGroup, count);
+    size_t group_count = 0;
+
+    for (size_t i = 0; i < count; i++) {
+        const AppleDextBoundDevice *dev = &devices[i];
+        int group = apple_auto_group_for(groups, group_count, dev);
+
+        if (group < 0) {
+            if (group_count > guest_slot_start - 1) {
+                error_setg(errp,
+                           "too many VFIO PCI slots to auto-place starting at "
+                           "guest slot 0x%x",
+                           guest_slot_start);
+                g_free(groups);
+                return false;
+            }
+
+            group = (int)group_count++;
+            groups[group].bus = dev->bus;
+            groups[group].device = dev->device;
+            groups[group].first_function = dev->function;
+            groups[group].guest_slot = guest_slot_start - (uint8_t)group;
+            groups[group].count = 0;
+            strncpy(groups[group].root, dev->root,
+                    sizeof(groups[group].root) - 1);
+            groups[group].root[sizeof(groups[group].root) - 1] = '\0';
+        }
+
+        groups[group].count++;
+    }
+
+    *out_groups = groups;
+    *out_group_count = group_count;
+    return true;
+}
+
+static bool
+apple_auto_should_attach(const AppleDextBoundDevice *dev)
+{
+    /*
+     * HDMI/DP audio functions on GPUs are not useful for the compute runtime
+     * and add extra guest drivers/DMA endpoints during early boot. Keep the
+     * display/compute function for every card, but leave GPU audio on macOS.
+     */
+    if ((dev->class_code & 0xffff00) == 0x040300) {
+        warn_report("vfio-apple-auto-pci: skipping GPU audio function "
+                    "%02x:%02x.%x@%s vendor=%04x device=%04x",
+                    dev->bus, dev->device, dev->function,
+                    dev->root[0] ? dev->root : "?",
+                    dev->vendor_id, dev->device_id);
+        return false;
+    }
+
+    return true;
+}
+
+static bool
+apple_auto_create_one(PCIBus *bus, const VFIOAppleAutoPCIDevice *auto_dev,
+                      const AppleDextBoundDevice *dev,
+                      const AppleAutoGroup *group,
+                      Error **errp)
+{
+    g_autofree char *host_bdf = NULL;
+    PCIDevice *pci_dev;
+    Object *obj;
+    uint8_t guest_function = dev->function - group->first_function;
+    bool multifunction = group->count > 1 && guest_function == 0;
+
+    if (guest_function > 7) {
+        error_setg(errp,
+                   "host slot %02x:%02x under root '%s' spans more than 8 "
+                   "functions; cannot map to one guest multifunction slot",
+                   dev->bus, dev->device,
+                   group->root[0] ? group->root : "?");
+        return false;
+    }
+
+    pci_dev = multifunction
+        ? pci_new_multifunction(PCI_DEVFN(group->guest_slot, guest_function),
+                                TYPE_VFIO_APPLE_PCI)
+        : pci_new(PCI_DEVFN(group->guest_slot, guest_function),
+                  TYPE_VFIO_APPLE_PCI);
+    obj = OBJECT(pci_dev);
+
+    host_bdf = g_strdup_printf("%02x:%02x.%x",
+                               dev->bus, dev->device, dev->function);
+    if (!object_property_set_str(obj, "host", host_bdf, errp) ||
+        !object_property_set_bool(obj, "dma-companion",
+                                  auto_dev->dma_companion, errp) ||
+        !object_property_set_uint(obj, "dma-bounce-size",
+                                  auto_dev->dma_bounce_size, errp) ||
+        !object_property_set_int(obj, "rombar", 0, errp)) {
+        object_unref(obj);
+        return false;
+    }
+
+    if (dev->root[0] != '\0' &&
+        !object_property_set_str(obj, "host-root", dev->root, errp)) {
+        object_unref(obj);
+        return false;
+    }
+
+    info_report("vfio-apple-auto-pci: attaching %s@%s vendor=%04x "
+                "device=%04x class=%06x (%s) as guest %02x:%02x.%x",
+                host_bdf, dev->root[0] ? dev->root : "?",
+                dev->vendor_id, dev->device_id, dev->class_code,
+                dev->name, 0, group->guest_slot, guest_function);
+    return pci_realize_and_unref(pci_dev, bus, errp);
+}
+
+static void
+vfio_apple_auto_pci_realize(DeviceState *dev, Error **errp)
+{
+    VFIOAppleAutoPCIDevice *auto_dev = VFIO_APPLE_AUTO_PCI(dev);
+    g_autofree AppleAutoGroup *groups = NULL;
+    AppleDextBoundDevice *bound = NULL;
+    size_t bound_count = 0;
+    size_t group_count = 0;
+    g_autofree char *enum_err = NULL;
+    PCIBus *bus;
+
+    bus = apple_auto_primary_pci_bus();
+    if (bus == NULL) {
+        error_setg(errp, "vfio-apple-auto-pci: no PCI bus is available");
+        return;
+    }
+
+    if (!apple_dext_copy_bound_devices(&bound, &bound_count, &enum_err)) {
+        error_setg(errp, "vfio-apple-auto-pci: %s",
+                   enum_err ? enum_err : "failed to enumerate VFIO devices");
+        return;
+    }
+
+    if (bound_count == 0) {
+        warn_report("vfio-apple-auto-pci: no VFIOUserPCIDriver-bound PCI "
+                    "functions found; booting without passthrough devices");
+        return;
+    }
+
+    qsort(bound, bound_count, sizeof(bound[0]), apple_dext_bound_device_cmp);
+
+    size_t attach_count = 0;
+    for (size_t i = 0; i < bound_count; i++) {
+        if (apple_auto_should_attach(&bound[i])) {
+            if (attach_count != i) {
+                bound[attach_count] = bound[i];
+            }
+            attach_count++;
+        }
+    }
+
+    if (attach_count == 0) {
+        warn_report("vfio-apple-auto-pci: no attachable PCI functions after "
+                    "filtering; booting without passthrough devices");
+        apple_dext_free_bound_devices(bound);
+        return;
+    }
+
+    if (!apple_auto_prepare_groups(bound, attach_count,
+                                   auto_dev->guest_slot_start,
+                                   &groups, &group_count, errp)) {
+        apple_dext_free_bound_devices(bound);
+        return;
+    }
+
+    for (size_t i = 0; i < attach_count; i++) {
+        int group_index = apple_auto_group_for(groups, group_count, &bound[i]);
+
+        if (group_index < 0 ||
+            !apple_auto_create_one(bus, auto_dev, &bound[i],
+                                   &groups[group_index], errp)) {
+            apple_dext_free_bound_devices(bound);
+            return;
+        }
+    }
+
+    apple_dext_free_bound_devices(bound);
+}
+
+static const Property vfio_apple_auto_pci_properties[] = {
+    DEFINE_PROP_BOOL("dma-companion", VFIOAppleAutoPCIDevice,
+                     dma_companion, true),
+    DEFINE_PROP_SIZE("dma-bounce-size", VFIOAppleAutoPCIDevice,
+                     dma_bounce_size, 64 * MiB),
+    DEFINE_PROP_UINT8("guest-slot-start", VFIOAppleAutoPCIDevice,
+                      guest_slot_start, 0x1e),
+};
+
+static void
+vfio_apple_auto_pci_class_init(ObjectClass *klass, const void *data)
+{
+    DeviceClass *dc = DEVICE_CLASS(klass);
+
+    dc->realize = vfio_apple_auto_pci_realize;
+    device_class_set_props(dc, vfio_apple_auto_pci_properties);
+    set_bit(DEVICE_CATEGORY_MISC, dc->categories);
+}
+
+static const TypeInfo vfio_apple_auto_pci_info = {
+    .name = TYPE_VFIO_APPLE_AUTO_PCI,
+    .parent = TYPE_DEVICE,
+    .instance_size = sizeof(VFIOAppleAutoPCIDevice),
+    .class_init = vfio_apple_auto_pci_class_init,
+};
+
+static void
+register_vfio_apple_auto_pci_type(void)
+{
+    type_register_static(&vfio_apple_auto_pci_info);
+}
+
+type_init(register_vfio_apple_auto_pci_type)
