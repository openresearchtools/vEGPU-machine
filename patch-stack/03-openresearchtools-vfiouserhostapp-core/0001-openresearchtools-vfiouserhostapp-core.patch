+    -Dtests=false \
+    -Dsasl=false \
+    -Dsmartcard=disabled \
+    -Dopus=enabled \
+    -Dgstreamer=1.0
+ninja -C "$WORK/spice-server-build" install
+
+PKG_CONFIG_PATH="$DEPS_PKG_CONFIG_PATH" \
