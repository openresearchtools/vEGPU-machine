+func parseJSONOptions(_ argv: [String], command: String) -> Bool {
+    var json = false
+    for arg in argv {
+        switch arg {
+        case "--json":
+            json = true
+        case "--help", "-h":
+            printUsage()
+            exit(0)
+        default:
+            die("unknown flag for \(command): \(arg) (try `qemu-vfio-apple help`)")
+        }
+    }
+    return json
+}
+
+func parseDriverSetupOptions(_ argv: [String]) -> Bool {
+    var gui = true
+    for arg in argv {
+        switch arg {
+        case "--gui":
+            gui = true
+        case "--help", "-h":
+            printUsage()
+            exit(0)
+        default:
+            die("unknown flag for driver-setup: \(arg) (try `qemu-vfio-apple help`)")
+        }
+    }
+    return gui
+}
+
+func printJSON<T: Encodable>(_ value: T) {
+    let encoder = JSONEncoder()
+    encoder.outputFormatting = [.prettyPrinted, .sortedKeys]
+    do {
+        let data = try encoder.encode(value)
+        if let text = String(data: data, encoding: .utf8) {
+            print(text)
+        }
+    } catch {
+        die("failed to encode JSON: \(error.localizedDescription)")
+    }
+}
