-
-private final class PathCheck {
-    static let shared = PathCheck()
-
-    private let lock = NSLock()
-    private var cache: [String: Bool] = [:]
-
-    func contains(_ dir: String) -> Bool {
-        lock.lock()
-        if let cached = cache[dir] {
-            lock.unlock()
-            return cached
-        }
-        lock.unlock()
-
-        let result = computeContains(dir)
-
-        lock.lock()
-        cache[dir] = result
-        lock.unlock()
-        return result
-    }
-
-    func invalidate() {
-        lock.lock()
-        cache.removeAll()
-        lock.unlock()
-    }
-
-    private func computeContains(_ dir: String) -> Bool {
-        if let inherited = ProcessInfo.processInfo.environment["PATH"],
-           splitPath(inherited).contains(dir)
-        {
-            return true
-        }
-        if let user = userShellPath(), splitPath(user).contains(dir) {
-            return true
-        }
-        return false
-    }
-
-    private func splitPath(_ s: String) -> [String] {
-        s.split(separator: ":").map(String.init)
-    }
-
-    /// Asks the user's login + interactive shell what `$PATH` it produces.
-    /// Bounded to ~2s so a misbehaving rc file can't stall the UI.
-    private func userShellPath() -> String? {
-        let shell = ProcessInfo.processInfo.environment["SHELL"] ?? "/bin/zsh"
-        guard FileManager.default.isExecutableFile(atPath: shell) else { return nil }
-
-        let task = Process()
-        task.executableURL = URL(fileURLWithPath: shell)
-        // -l: source profile/login files (.zprofile / .profile)
-        // -i: source interactive rc files (.zshrc / .bashrc) — most users
-        //     set PATH there
-        task.arguments = ["-l", "-i", "-c", "printf %s \"$PATH\""]
-        let stdout = Pipe()
-        let stderr = Pipe()
-        task.standardOutput = stdout
-        task.standardError = stderr
-        task.standardInput = FileHandle(forReadingAtPath: "/dev/null")
-
-        do {
-            try task.run()
-        } catch {
-            return nil
-        }
-
-        let deadline = Date().addingTimeInterval(2.0)
-        while task.isRunning && Date() < deadline {
-            Thread.sleep(forTimeInterval: 0.05)
-        }
-        if task.isRunning {
-            task.terminate()
-            return nil
-        }
-
-        let data = stdout.fileHandleForReading.readDataToEndOfFile()
-        let s = String(data: data, encoding: .utf8)?
-            .trimmingCharacters(in: .whitespacesAndNewlines)
-        return (s?.isEmpty ?? true) ? nil : s
-    }
-}
