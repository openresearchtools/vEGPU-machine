+
+static bool
+cf_string_get_utf8(CFStringRef str, char *out, size_t out_size)
+{
+    if (str == NULL || out == NULL || out_size == 0) {
+        return false;
+    }
+    out[0] = '\0';
+    return CFStringGetCString(str, out, out_size, kCFStringEncodingUTF8);
+}
+
+static bool
+cf_data_read_u16_le(CFTypeRef ref, uint16_t *out)
+{
+    const UInt8 *bytes;
+    CFIndex len;
+
+    if (ref == NULL || CFGetTypeID(ref) != CFDataGetTypeID() || out == NULL) {
+        return false;
+    }
+    len = CFDataGetLength((CFDataRef)ref);
+    if (len < 2) {
+        return false;
+    }
+    bytes = CFDataGetBytePtr((CFDataRef)ref);
+    *out = (uint16_t)bytes[0] | ((uint16_t)bytes[1] << 8);
+    return true;
+}
+
+static bool
+cf_data_read_u32_le(CFTypeRef ref, uint32_t *out)
+{
+    const UInt8 *bytes;
+    CFIndex len;
+
+    if (ref == NULL || CFGetTypeID(ref) != CFDataGetTypeID() || out == NULL) {
+        return false;
+    }
+    len = CFDataGetLength((CFDataRef)ref);
+    if (len < 4) {
+        return false;
+    }
+    bytes = CFDataGetBytePtr((CFDataRef)ref);
+    *out = (uint32_t)bytes[0] |
+           ((uint32_t)bytes[1] << 8) |
+           ((uint32_t)bytes[2] << 16) |
+           ((uint32_t)bytes[3] << 24);
+    return true;
+}
+
+static bool
+parse_pcidebug_bdf(CFTypeRef ref, uint8_t *bus, uint8_t *device,
+                   uint8_t *function)
+{
+    char buf[128];
+    unsigned b, d, f;
+
+    if (ref == NULL || CFGetTypeID(ref) != CFStringGetTypeID()) {
+        return false;
+    }
+    if (!cf_string_get_utf8((CFStringRef)ref, buf, sizeof(buf))) {
+        return false;
+    }
+    if (sscanf(buf, "%u:%u:%u", &b, &d, &f) != 3 ||
+        b > UINT8_MAX || d > UINT8_MAX || f > UINT8_MAX) {
+        return false;
+    }
+
+    *bus = (uint8_t)b;
+    *device = (uint8_t)d;
+    *function = (uint8_t)f;
+    return true;
+}
+
+static void
+copy_pci_name(CFTypeRef ref, char *out, size_t out_size)
+{
+    const UInt8 *bytes;
+    CFIndex len;
+    size_t copy_len;
+
+    if (out == NULL || out_size == 0) {
+        return;
+    }
+    out[0] = '\0';
+
+    if (ref == NULL) {
+        return;
+    }
+    if (CFGetTypeID(ref) == CFStringGetTypeID()) {
+        cf_string_get_utf8((CFStringRef)ref, out, out_size);
+        return;
+    }
+    if (CFGetTypeID(ref) != CFDataGetTypeID()) {
+        return;
+    }
+
+    bytes = CFDataGetBytePtr((CFDataRef)ref);
+    len = CFDataGetLength((CFDataRef)ref);
+    if (bytes == NULL || len <= 0) {
+        return;
+    }
+
+    copy_len = MIN((size_t)len, out_size - 1);
+    memcpy(out, bytes, copy_len);
+    out[copy_len] = '\0';
+}
+
+static bool
+dext_bundle_identifier_matches(CFTypeRef ref)
+{
+    char buf[256];
+    const char *suffix = ".VFIOUserPCIDriver";
+    size_t len;
+    size_t suffix_len;
+
+    if (ref == NULL || CFGetTypeID(ref) != CFStringGetTypeID()) {
+        return false;
+    }
+    if (!cf_string_get_utf8((CFStringRef)ref, buf, sizeof(buf))) {
+        return false;
+    }
+
+    len = strlen(buf);
+    suffix_len = strlen(suffix);
+    return len >= suffix_len &&
+           strcmp(buf + len - suffix_len, suffix) == 0;
+}
+
+static bool
+pci_device_bound_to_vfio_dext(io_service_t pci_dev)
+{
+    io_iterator_t iterator = IO_OBJECT_NULL;
+    io_object_t child;
+    kern_return_t kr;
+
+    kr = IORegistryEntryGetChildIterator(pci_dev, kIOServicePlane, &iterator);
+    if (kr != KERN_SUCCESS) {
+        return false;
+    }
+
+    while ((child = IOIteratorNext(iterator)) != IO_OBJECT_NULL) {
+        CFTypeRef bundle_id;
+        io_name_t name;
+        bool match = false;
+
+        bundle_id = IORegistryEntryCreateCFProperty(child,
+                                                    CFSTR("CFBundleIdentifier"),
+                                                    kCFAllocatorDefault, 0);
+        if (dext_bundle_identifier_matches(bundle_id)) {
+            match = true;
+        }
+        if (bundle_id != NULL) {
+            CFRelease(bundle_id);
+        }
+
+        if (!match &&
+            IORegistryEntryGetName(child, name) == KERN_SUCCESS &&
+            strcmp(name, "VFIOUserPCIDriver") == 0) {
+            match = true;
+        }
+
+        IOObjectRelease(child);
+        if (match) {
+            IOObjectRelease(iterator);
+            return true;
+        }
+    }
+
+    IOObjectRelease(iterator);
+    return false;
+}
+
+bool
+apple_dext_copy_bound_devices(AppleDextBoundDevice **out_devices,
+                              size_t *out_count,
+                              char **errp)
+{
+    CFMutableDictionaryRef matching;
+    io_iterator_t iterator = IO_OBJECT_NULL;
+    io_service_t pci_dev;
+    kern_return_t kr;
+    AppleDextBoundDevice *devices = NULL;
+    size_t count = 0;
+    size_t capacity = 0;
+
+    if (out_devices == NULL || out_count == NULL) {
+        if (errp != NULL && *errp == NULL) {
+            *errp = strdup("invalid output pointer for dext device enumeration");
+        }
+        return false;
+    }
+    *out_devices = NULL;
+    *out_count = 0;
+
+    matching = IOServiceMatching("IOPCIDevice");
+    if (matching == NULL) {
+        if (errp != NULL && *errp == NULL) {
+            *errp = strdup("failed to create IOPCIDevice matching dictionary");
+        }
+        return false;
+    }
+
+    kr = IOServiceGetMatchingServices(kIOMainPortDefault, matching, &iterator);
+    if (kr != KERN_SUCCESS) {
+        if (errp != NULL && *errp == NULL) {
+            *errp = strdup("failed to enumerate IOPCIDevice services");
+        }
+        return false;
+    }
+
+    while ((pci_dev = IOIteratorNext(iterator)) != IO_OBJECT_NULL) {
+        AppleDextBoundDevice info = {0};
+        CFTypeRef pcidebug = NULL;
+        CFTypeRef vendor = NULL;
+        CFTypeRef device = NULL;
+        CFTypeRef class_code = NULL;
+        CFTypeRef name = NULL;
+
+        if (!pci_device_bound_to_vfio_dext(pci_dev)) {
+            IOObjectRelease(pci_dev);
+            continue;
+        }
+
+        pcidebug = IORegistryEntryCreateCFProperty(pci_dev, CFSTR("pcidebug"),
+                                                   kCFAllocatorDefault, 0);
+        if (!parse_pcidebug_bdf(pcidebug, &info.bus, &info.device,
+                                &info.function)) {
+            if (pcidebug != NULL) {
+                CFRelease(pcidebug);
+            }
+            IOObjectRelease(pci_dev);
+            continue;
+        }
+        CFRelease(pcidebug);
+
+        vendor = IORegistryEntryCreateCFProperty(pci_dev, CFSTR("vendor-id"),
+                                                 kCFAllocatorDefault, 0);
+        device = IORegistryEntryCreateCFProperty(pci_dev, CFSTR("device-id"),
+                                                 kCFAllocatorDefault, 0);
+        class_code = IORegistryEntryCreateCFProperty(pci_dev,
+                                                     CFSTR("class-code"),
+                                                     kCFAllocatorDefault, 0);
+        name = IORegistryEntryCreateCFProperty(pci_dev, CFSTR("name"),
+                                               kCFAllocatorDefault, 0);
+
+        cf_data_read_u16_le(vendor, &info.vendor_id);
+        cf_data_read_u16_le(device, &info.device_id);
+        cf_data_read_u32_le(class_code, &info.class_code);
+        copy_pci_name(name, info.name, sizeof(info.name));
+        if (info.name[0] == '\0') {
+            snprintf(info.name, sizeof(info.name), "pci%04x,%04x",
+                     info.vendor_id, info.device_id);
+        }
+        if (!dext_root_name(pci_dev, info.root, sizeof(info.root))) {
+            info.root[0] = '\0';
+        }
+
+        if (vendor != NULL) {
+            CFRelease(vendor);
+        }
+        if (device != NULL) {
+            CFRelease(device);
+        }
+        if (class_code != NULL) {
+            CFRelease(class_code);
+        }
+        if (name != NULL) {
+            CFRelease(name);
+        }
+
+        if (count == capacity) {
+            capacity = capacity == 0 ? 8 : capacity * 2;
+            devices = g_renew(AppleDextBoundDevice, devices, capacity);
+        }
+        devices[count++] = info;
+        IOObjectRelease(pci_dev);
+    }
+
+    IOObjectRelease(iterator);
+
+    *out_devices = devices;
+    *out_count = count;
+    return true;
+}
+
+void
+apple_dext_free_bound_devices(AppleDextBoundDevice *devices)
+{
+    g_free(devices);
+}
