-/// Splices out the marker-delimited block (and one collapsed leading blank
-/// line, if present) from `file`. Returns true iff anything was removed.
-private func removePathSnippet(from file: URL) throws -> Bool {
-    let original = try String(contentsOf: file, encoding: .utf8)
-    guard original.contains(kPathSnippetMarker) else { return false }
-
-    var lines = original.components(separatedBy: "\n")
-    var start: Int?
-    var end: Int?
-    for (i, line) in lines.enumerated() {
-        if start == nil, line.contains(kPathSnippetMarker) { start = i }
-        if start != nil, line.contains(kPathSnippetEndMarker) {
-            end = i
-            break
-        }
-    }
-    guard let s = start, let e = end, s <= e else {
-        // Start marker present but end marker missing — leave the file alone
-        // rather than potentially nuke unrelated content.
-        return false
-    }
-
-    lines.removeSubrange(s...e)
-    if s > 0 && lines[s - 1].isEmpty {
-        lines.remove(at: s - 1)
-    }
-    let newContent = lines.joined(separator: "\n")
-    try newContent.write(to: file, atomically: true, encoding: .utf8)
-    return true
 }

